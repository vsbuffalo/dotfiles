#!/usr/bin/env bash
# start-agents — launch parallel Claude Code agents in tmux
#
# Directory mode:  start-agents ~/proj-a ~/proj-b
# Worktree mode:   start-agents --worktree ~/repo 3
#
# By default, agents share one window as tiled panes (--panes).
# Use --windows to give each agent its own window instead.

set -euo pipefail

SESSION="agents"
LAYOUT="panes"   # default

usage() {
  cat <<'EOF'
Usage:
  start-agents [options] <dir> [<dir> ...]
  start-agents [options] --worktree <repo> <count>

Options:
  --panes       All agents in one window as tiled panes (default)
  --windows     Each agent gets its own window
  --worktree    Create <count> worktrees under <repo>/.worktrees/
  -h, --help    Show this help

Examples:
  start-agents ~/project-a ~/project-b
  start-agents --worktree ~/my-repo 3
  start-agents --windows --worktree ~/my-repo 3
EOF
  exit "${1:-0}"
}

# --- Worktree helper ---
create_worktrees() {
  local repo="$1"
  local count="$2"
  local wt_base="$repo/.worktrees"
  local date_tag
  date_tag=$(date +%Y%m%d)

  mkdir -p "$wt_base"

  local dirs=()
  for i in $(seq 1 "$count"); do
    local branch="agent/${date_tag}-${i}"
    local wt_dir="$wt_base/${date_tag}-${i}"

    if [[ -d "$wt_dir" ]]; then
      dirs+=("$wt_dir")
    else
      git -C "$repo" worktree add "$wt_dir" -b "$branch" 2>/dev/null \
        || git -C "$repo" worktree add "$wt_dir" "$branch"
      dirs+=("$wt_dir")
    fi
  done

  printf '%s\n' "${dirs[@]}"
}

# --- Parse arguments ---
WORKTREE=false
DIRS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)   usage 0 ;;
    --panes)     LAYOUT="panes"; shift ;;
    --windows)   LAYOUT="windows"; shift ;;
    --worktree)
      WORKTREE=true
      shift
      [[ $# -ge 2 ]] || { echo "error: --worktree requires <repo> <count>" >&2; usage 1; }
      REPO="$1"; COUNT="$2"
      shift 2
      ;;
    *)
      DIRS+=("$1")
      shift
      ;;
  esac
done

# Resolve directories
if $WORKTREE; then
  [[ -d "$REPO/.git" || -f "$REPO/.git" ]] || { echo "error: $REPO is not a git repository" >&2; exit 1; }
  mapfile -t DIRS < <(create_worktrees "$REPO" "$COUNT")
fi

[[ ${#DIRS[@]} -gt 0 ]] || { echo "error: no directories specified" >&2; usage 1; }

# --- Build tmux session ---
if tmux has-session -t "$SESSION" 2>/dev/null; then
  echo "Session '$SESSION' exists — reattaching."
  exec tmux attach-session -t "$SESSION"
fi

N=${#DIRS[@]}
FIRST=true

if [[ "$LAYOUT" == "panes" ]]; then
  # All agents in one window, tiled
  WIN_NAME="agents-${N}"
  for dir in "${DIRS[@]}"; do
    dir="$(cd "$dir" && pwd)"

    if $FIRST; then
      tmux new-session -d -s "$SESSION" -n "$WIN_NAME" -c "$dir"
      FIRST=false
    else
      tmux split-window -t "$SESSION:$WIN_NAME" -c "$dir"
      tmux select-layout -t "$SESSION:$WIN_NAME" tiled
    fi

    tmux send-keys -t "$SESSION:$WIN_NAME" "claude" Enter
  done

  # Final tidy layout
  tmux select-layout -t "$SESSION:$WIN_NAME" tiled
  tmux select-pane -t "$SESSION:$WIN_NAME.1"
else
  # Each agent gets its own window
  for dir in "${DIRS[@]}"; do
    dir="$(cd "$dir" && pwd)"
    name="$(basename "$dir")"

    if $FIRST; then
      tmux new-session -d -s "$SESSION" -n "$name" -c "$dir"
      FIRST=false
    else
      tmux new-window -t "$SESSION" -n "$name" -c "$dir"
    fi

    tmux send-keys -t "$SESSION:$name" "claude" Enter
  done

  tmux select-window -t "$SESSION:1"
fi

echo "Session '$SESSION' created with $N agent(s) (layout: $LAYOUT)."
exec tmux attach-session -t "$SESSION"
