      "Bash(GOBIN=\"$HOME/.local/bin\" go install:*)",
      "Read(/Users/vsb/.local/bin/**)",
      "Bash(/Users/vsb/.local/bin/gatus:*)",
      "Bash(pgrep:*)"
    ],
    "deny": [
      "Bash(*git add -A*)",
      "Bash(git add --all*)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(rm -rf *)",
      "Read(./.env)",
      "Read(./.env.*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -re 'if (.tool_input.command | test(\"git add -A\")) then {\"permissionDecision\": \"deny\", \"permissionDecisionReason\": \"Use git add with specific files instead of -A\"} else empty end'"
          }
        ]
      }
    ]
  }
}
